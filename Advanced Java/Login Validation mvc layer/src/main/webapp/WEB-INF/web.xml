<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
  <display-name>LoginValidationPractise</display-name>
  
  <listener>
  	<listener-class>com.listener.DAOContextListener</listener-class>
  </listener>
  
  <context-param>
  		<param-name>driver</param-name>
  		<param-value>com.mysql.cj.jdbc.Driver</param-value>
  </context-param>
  
  <context-param>
  		<param-name>url</param-name>
  		<param-value>jdbc:mysql://localhost:3306/jdbc_practise</param-value>
  </context-param>
  
  <context-param>
  		<param-name>username</param-name>
  		<param-value>root</param-value>
  </context-param>
  
  <context-param>
  		<param-name>password</param-name>
  		<param-value>Rosh@ni2002</param-value>
  </context-param>
  
  <servlet>
  	<servlet-name>login</servlet-name>
  	<servlet-class>com.controller.LoginServlet</servlet-class>
  	<init-param>
  		<param-name>classname</param-name>
  		<param-value>com.serviceImpl.LoginValidationImpl</param-value>

  	</init-param>
  	
  	<init-param>
  		<param-name>daoclassname</param-name>
  		<param-value>com.daoImpl.DaoImpl</param-value>
  	</init-param>
  
  </servlet>
  
  <servlet>
  	<servlet-name>SignUp</servlet-name>
  	<servlet-class>com.controller.SignUpServlet</servlet-class>
  	<init-param>
  		<param-name>classname</param-name>
  		<param-value>com.serviceImpl.LoginValidationImpl</param-value>

  	</init-param>
  	
  	<init-param>
  		<param-name>daoclassname</param-name>
  		<param-value>com.daoImpl.DaoImpl</param-value>
  	</init-param>
  
  </servlet>
  
  <servlet-mapping>
  	<servlet-name>SignUp</servlet-name>
  	<url-pattern>/signUp</url-pattern>
  </servlet-mapping>
  
  <servlet-mapping>
  	<servlet-name>login</servlet-name>
  	<url-pattern>/log</url-pattern>
  </servlet-mapping>
</web-app>